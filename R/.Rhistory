dataList = Quant_dataList
parList = Quant_parList
indrng  <- c(0,100)
indfine <- seq(0,100,len=101)
sumscrsave <- simList$sumscr
thetasave  <- simList$theta
musave     <- simList$mu
alsave     <- simList$al
theta.pop  <- simList$thepop
mu.pop     <- simList$mupop
al.pop     <- simList$alpop
nsample <- dim(thetasave)[2]
ntheta  <- length(theta.pop)
thetares  <- thetasave  - matrix(theta.pop,ntheta,1) %*% matrix(1,1,nsample)
mures     <- musave     - matrix(mu.pop,ntheta,1)    %*% matrix(1,1,nsample)
alres     <- alsave     - matrix(al.pop,ntheta,1)    %*% matrix(1,1,nsample)
sumscrres <- sumscrsave - matrix(mu.pop ,ntheta,1)   %*% matrix(1,1,nsample)
thetabias  <- apply(thetares,  1, mean)
mubias     <- apply(mures,     1, mean)
albias     <- apply(alres,     1, mean)
sumscrbias <- apply(sumscrres, 1, mean)
#  compute RMSE"s averaged over only samples
thetaRMSE  <- sqrt(apply( thetares^2, 1, mean))
muRMSE     <- sqrt(apply(    mures^2, 1, mean))
alRMSE     <- sqrt(apply(    alres^2, 1, mean))
sumscrRMSE <- sqrt(apply(sumscrres^2, 1, mean))
#  percentize RMSE by multiplying by 100 and dividing by upper limit
thetaRMSE100  <- thetaRMSE
muRMSE100     <- muRMSE*100/dataList$scrrng[2]
alRMSE100     <- alRMSE*100/parList$arclength
sumscrRMSE100 <- sumscrRMSE*100/dataList$scrrng[2]
#  compute standard error"s averaged over only samples
thetastd  <- sqrt( thetaRMSE^2  -  thetabias^2)
mustd     <- sqrt(    muRMSE^2  -     mubias^2)
alstd     <- sqrt(    alRMSE^2  -     albias^2)
sumscrstd <- sqrt(sumscrRMSE^2  - sumscrbias^2)
#  normalize
#  Set up bases for returning smooth performance curves
indbasis <- create.bspline.basis(indrng, 21)
indfdPar <- fdPar(indbasis, 1, 1e0)
#  Lightly smooth bias results over theta"s
thetabiasfd  <- smooth.basis(theta.pop,  matrix(thetabias,ntheta,1), indfdPar)$fd
mubiasfd     <- smooth.basis(theta.pop,     matrix(mubias,ntheta,1), indfdPar)$fd
albiasfd     <- smooth.basis(theta.pop,     matrix(albias,ntheta,1), indfdPar)$fd
sumscrbiasfd <- smooth.basis(theta.pop, matrix(sumscrbias,ntheta,1), indfdPar)$fd
#  Lightly smooth RMSE results over theta"s
thetaRMSEfd  <- smooth.basis(theta.pop,  matrix(thetaRMSE,ntheta,1), indfdPar)$fd
muRMSEfd     <- smooth.basis(theta.pop,     matrix(muRMSE,ntheta,1), indfdPar)$fd
alRMSEfd     <- smooth.basis(theta.pop,     matrix(alRMSE,ntheta,1), indfdPar)$fd
sumscrRMSEfd <- smooth.basis(theta.pop, matrix(sumscrRMSE,ntheta,1), indfdPar)$fd
#  Lightly smooth RMSE results over theta"s
thetaRMSE100fd  <- smooth.basis(theta.pop,  matrix(thetaRMSE100,ntheta,1), indfdPar)$fd
muRMSE100fd     <- smooth.basis(theta.pop,     matrix(muRMSE100,ntheta,1), indfdPar)$fd
alRMSE100fd     <- smooth.basis(theta.pop,     matrix(alRMSE100,ntheta,1), indfdPar)$fd
sumscrRMSE100fd <- smooth.basis(theta.pop, matrix(sumscrRMSE100,ntheta,1), indfdPar)$fd
thetaRMSE100vec  <- eval.fd(indfine,  thetaRMSE100fd)
muRMSE100vec     <- eval.fd(indfine,     muRMSE100fd)
alRMSE100vec     <- eval.fd(indfine,     alRMSE100fd)
sumscrRMSE100vec <- eval.fd(indfine, sumscrRMSE100fd)
RMSE100 <- cbind(sumscrRMSE100vec, muRMSE100vec, alRMSE100vec)
RMSErng <- c(0,6)
matplot(indfine, RMSE100, type="l", col=c(2,2,3), lty=c(2,1,1),
lwd=2, xlab="Score Index", ylab="RMSE (%)")
